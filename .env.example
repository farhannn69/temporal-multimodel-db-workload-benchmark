# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=temporal_bench
POSTGRES_USER=bench_user
POSTGRES_PASSWORD=bench_pass

# ─────────────────────────────────────────
# MongoDB
# ─────────────────────────────────────────
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=temporal_bench
MONGO_USER=bench_user
MONGO_PASSWORD=bench_pass

# ─────────────────────────────────────────
# Neo4j
# ─────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bench_pass

# ─────────────────────────────────────────
# Benchmark settings
# ─────────────────────────────────────────
BENCHMARK_REPETITIONS=5
NUM_TIME_STEPS=12
